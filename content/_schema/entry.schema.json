{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "hd-tea content entry frontmatter",
  "type": "object",
  "required": ["type", "category", "title", "desc", "status"],
  "properties": {
    "type": { "enum": ["tea", "tisane", "region", "topic", "hub"] },
    "category": {
      "enum": ["regions", "teas", "tisanes", "cultivation", "harvest", "processing", "storage", "brewing", "tasting", "teaware", "hubs"]
    },
    "title": { "type": "string", "minLength": 1 },
    "native": { "type": "string" },
    "reading": { "type": "string" },
    "desc": { "type": "string", "minLength": 10, "maxLength": 220 },
    "metaDesc": { "type": "string", "maxLength": 170 },
    "tags": { "type": "array", "items": { "type": "string" } },
    "status": { "enum": ["stub", "complete"] },
    "updated": {},
    "content_review": { "enum": ["verified", "pending", "unverified"] },
    "content_sources": { "type": "array", "items": { "type": "string" } },

    "tea_type": { "enum": ["green", "white", "yellow", "oolong", "black", "dark", "tisane"] },
    "liquor": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
    "origin": { "type": "string" },
    "cultivar": { "type": "string" },
    "elevation_m": { "type": ["number", "string"] },
    "oxidation": { "type": "string" },
    "roast": { "type": "string" },
    "harvest_season": { "type": "string" },
    "steeps": {
      "type": "object",
      "required": ["times"],
      "properties": {
        "temp_c": { "type": "number", "minimum": 40, "maximum": 100 },
        "grams": { "type": "number" },
        "ml": { "type": "number" },
        "vessel": { "type": "string" },
        "rinse": { "type": "boolean" },
        "times": { "type": "array", "items": { "type": "number", "minimum": 1 }, "minItems": 1, "maxItems": 15 },
        "note": { "type": "string" }
      }
    },

    "country": { "type": "string" },
    "elevation_range": { "type": "string" },
    "known_for": { "type": "array", "items": { "type": "string" } },
    "map": {
      "type": "object",
      "required": ["center", "span_km"],
      "properties": {
        "center": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 2,
          "maxItems": 2,
          "description": "[lon, lat] of the detail window center"
        },
        "span_km": { "type": "number", "minimum": 5, "maximum": 3000 },
        "elevation_label": { "type": "string" },
        "water_label": { "type": "string" },
        "markers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "lon", "lat"],
            "properties": {
              "name": { "type": "string" },
              "lon": { "type": "number", "minimum": -180, "maximum": 180 },
              "lat": { "type": "number", "minimum": -90, "maximum": 90 },
              "primary": { "type": "boolean" }
            }
          }
        },
        "caption": { "type": "string" }
      }
    },

    "hub_key": { "enum": ["library", "origins", "craft", "table"] }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "enum": ["tea", "tisane"] } } },
      "then": { "required": ["tea_type", "liquor"] }
    },
    {
      "if": { "properties": { "type": { "const": "region" } } },
      "then": { "required": ["country"] }
    },
    {
      "if": { "properties": { "type": { "const": "hub" } } },
      "then": { "required": ["hub_key"] }
    },
    {
      "if": { "properties": { "status": { "const": "complete" } }, "required": ["status"] },
      "then": { "required": ["content_review", "updated"] }
    },
    {
      "if": { "properties": { "content_review": { "const": "verified" } }, "required": ["content_review"] },
      "then": { "required": ["content_sources"], "properties": { "content_sources": { "minItems": 1 } } }
    }
  ]
}
